{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "FormOCR Template",
  "type": "object",
  "required": ["form_type", "version", "fields"],
  "properties": {
    "form_type": { "type": "string" },
    "version": { "type": "integer" },
    "anchors": { "type": "array", "items": { "type": "string" } },
    "fields": {
      "type": "object",
      "additionalProperties": {
        "type": "object",
        "required": ["bbox_norm", "field_type"],
        "properties": {
          "bbox_norm": {
            "type": "array",
            "items": { "type": "number" },
            "minItems": 4,
            "maxItems": 4
          },
          "field_type": {
            "enum": ["name", "phone", "date", "number", "email", "custom"]
          },
          "tolerance": { "type": "number" },
          "label": { "type": "string" }
        }
      }
    }
  }
}
