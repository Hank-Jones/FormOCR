FORMOCR_DATA_DIR=%LOCALAPPDATA%\FormOCR
FORMOCR_PORT=8765
FORMOCR_OLLAMA_HOST=http://127.0.0.1:11435
# Offline / production: vision OCR only (no text LLM for AI correction)
FORMOCR_OCR_ENGINE=qwen
FORMOCR_HANDWRITING_OCR_ENABLED=true
FORMOCR_HANDWRITING_OCR_MODEL=qwen2.5vl:3b
FORMOCR_AI_CORRECTION_ENABLED=false
