{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "FormOCR",
  "version": "1.0.0",
  "identifier": "com.formocr.app",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://127.0.0.1:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "FormOCR",
        "width": 1280,
        "height": 800,
        "minWidth": 900,
        "minHeight": 600,
        "devtools": true,
        "theme": "Dark",
        "backgroundColor": "#070b12"
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": [],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.png",
      "icons/icon.ico",
      "icons/icon.icns"
    ],
    "resources": [
      "resources/**/*"
    ]
  },
  "plugins": {}
}
